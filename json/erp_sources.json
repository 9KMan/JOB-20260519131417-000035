{
  "erp_sources": [
    {
      "source_id": "sage",
      "source_name": "Sage ERP",
      "connection": {
        "server": "${SAGE_SERVER}",
        "database": "${SAGE_DATABASE}",
        "schema": "dbo",
        "auth_type": "windows"
      },
      "tables": [
        {
          "table_name": "sales_orders",
          "stage_table": "stage_sage_sales_orders",
          "watermark_column": "LastModified",
          "primary_key": "OrderID",
          "column_mapping": {
            "OrderID": "source_id",
            "CustomerID": "natural_key",
            "OrderDate": "order_date",
            "TotalAmount": "total_amount"
          }
        },
        {
          "table_name": "invoices",
          "stage_table": "stage_sage_invoices",
          "watermark_column": "LastModified",
          "primary_key": "InvoiceID",
          "column_mapping": {
            "InvoiceID": "source_id",
            "OrderID": "order_id",
            "InvoiceDate": "invoice_date",
            "InvoiceAmount": "amount"
          }
        }
      ]
    },
    {
      "source_id": "sap",
      "source_name": "SAP ERP",
      "connection": {
        "server": "${SAP_SERVER}",
        "database": "${SAP_DATABASE}",
        "schema": "dbo",
        "auth_type": "sql"
      },
      "tables": [
        {
          "table_name": "sales_orders",
          "stage_table": "stage_sap_sales_orders",
          "watermark_column": "MODIFIED_TS",
          "primary_key": "VBELN",
          "column_mapping": {
            "VBELN": "source_id",
            "KUNNR": "natural_key",
            "AUDAT": "order_date",
            "NETWR": "total_amount"
          }
        },
        {
          "table_name": "invoices",
          "stage_table": "stage_sap_invoices",
          "watermark_column": "MODIFIED_TS",
          "primary_key": "INVNUM",
          "column_mapping": {
            "INVNUM": "source_id",
            "VBELN": "order_id",
            "FKDAT": "invoice_date",
            "NETWR": "amount"
          }
        }
      ]
    },
    {
      "source_id": "custom",
      "source_name": "Custom ERP",
      "connection": {
        "server": "${CUSTOM_SERVER}",
        "database": "${CUSTOM_DATABASE}",
        "schema": "dbo",
        "auth_type": "sql"
      },
      "tables": [
        {
          "table_name": "inventory",
          "stage_table": "stage_custom_inventory",
          "watermark_column": "updated_at",
          "primary_key": "inventory_id",
          "column_mapping": {
            "inventory_id": "source_id",
            "product_sku": "natural_key",
            "warehouse_code": "location_key",
            "quantity_on_hand": "qty_on_hand",
            "last_updated": "updated_at"
          }
        }
      ]
    }
  ],
  "pipeline_config": {
    "bronze_batch_size": 10000,
    "silver_dedup_window_days": 30,
    "gold_surrogate_key_start": 1,
    "enable_data_quality_checks": true,
    "dead_letter_retry_count": 3
  }
}