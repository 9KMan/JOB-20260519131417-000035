{
  "workflows": [
    {
      "workflow_id": "order_to_cash",
      "workflow_name": "Order to Cash",
      "description": "Sales order through shipment lifecycle",
      "screens": [
        {
          "screen_id": "sales_orders",
          "screen_name": "Sales Orders",
          "table_view": "vw_sales_orders_list",
          "edit_proc": "usp_etl_run_bronze_load",
          "fields": [
            {"field": "OrderNumber", "label": "Order #", "type": "string", "required": true},
            {"field": "CustomerName", "label": "Customer", "type": "lookup", "source": "DimCustomer"},
            {"field": "OrderDate", "label": "Order Date", "type": "date", "required": true},
            {"field": "TotalAmount", "label": "Total", "type": "currency", "required": true}
          ],
          "valid_states": ["Draft", "Submitted", "Confirmed", "Shipped", "Invoiced", "Closed"],
          "state_transitions": {
            "Draft": ["Submitted"],
            "Submitted": ["Confirmed"],
            "Confirmed": ["Shipped"],
            "Shipped": ["Invoiced"],
            "Invoiced": ["Closed"]
          }
        },
        {
          "screen_id": "invoices",
          "screen_name": "Invoices",
          "table_view": "vw_invoices_list",
          "fields": [
            {"field": "InvoiceNumber", "label": "Invoice #", "type": "string"},
            {"field": "CustomerName", "label": "Customer", "type": "lookup"},
            {"field": "InvoiceDate", "label": "Date", "type": "date"},
            {"field": "Amount", "label": "Amount", "type": "currency"}
          ]
        },
        {
          "screen_id": "shipments",
          "screen_name": "Shipments",
          "table_view": "vw_shipment_tracking",
          "fields": [
            {"field": "ShipmentNumber", "label": "Shipment #", "type": "string"},
            {"field": "CustomerName", "label": "Customer", "type": "lookup"},
            {"field": "ShipDate", "label": "Ship Date", "type": "date"},
            {"field": "Carrier", "label": "Carrier", "type": "string"}
          ]
        }
      ]
    },
    {
      "workflow_id": "procurement",
      "workflow_name": "Procurement",
      "description": "Purchase order lifecycle",
      "screens": [
        {
          "screen_id": "purchase_orders",
          "screen_name": "Purchase Orders",
          "table_view": "vw_procurement_summary",
          "fields": [
            {"field": "PONumber", "label": "PO #", "type": "string"},
            {"field": "VendorName", "label": "Vendor", "type": "lookup"},
            {"field": "PODate", "label": "Date", "type": "date"},
            {"field": "TotalAmount", "label": "Total", "type": "currency"},
            {"field": "Status", "label": "Status", "type": "enum"}
          ],
          "valid_states": ["Draft", "Submitted", "Approved", "Received", "Closed"],
          "state_transitions": {
            "Draft": ["Submitted"],
            "Submitted": ["Approved"],
            "Approved": ["Received"],
            "Received": ["Closed"]
          }
        }
      ]
    },
    {
      "workflow_id": "inventory",
      "workflow_name": "Inventory Management",
      "description": "Stock levels and movements",
      "screens": [
        {
          "screen_id": "inventory_levels",
          "screen_name": "Inventory Levels",
          "table_view": "vw_inventory_summary",
          "fields": [
            {"field": "ProductName", "label": "Product", "type": "lookup"},
            {"field": "WarehouseName", "label": "Warehouse", "type": "lookup"},
            {"field": "QuantityOnHand", "label": "On Hand", "type": "number"},
            {"field": "QuantityAvailable", "label": "Available", "type": "number"}
          ]
        }
      ]
    }
  ],
  "roles": [
    {"role": "admin", "can_access_all": true},
    {"role": "sales", "workflows": ["order_to_cash"]},
    {"role": "purchasing", "workflows": ["procurement"]},
    {"role": "warehouse", "workflows": ["inventory"]},
    {"role": "readonly", "workflows": [], "read_only": true}
  ]
}